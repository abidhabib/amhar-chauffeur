// =====================================================================
// AMHAR — Luxury Chauffeur Lead Management Platform
// Prisma schema
// =====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------
// LEADS — the core entity of the platform
// Status workflow: new → contacted → quoted → confirmed → cancelled
// ---------------------------------------------------------------------
model Lead {
  id              String   @id @default(cuid())
  reference       String   @unique
  status          String   @default("new") // new | contacted | quoted | confirmed | cancelled

  // Contact
  fullName        String
  email           String?
  phone           String
  countryCode     String   @default("+966")

  // Trip details
  pickup          String
  destination     String
  pickupDate      DateTime
  pickupTime      String // HH:mm
  vehicleCategory String // sedan | suv | van | bus
  vehicleId       String?
  passengers      Int      @default(1)
  luggage         Int      @default(0)
  notes           String?

  // Assignment
  assignedToId    String?

  assignedTo      User?    @relation("AssignedLeads", fields: [assignedToId], references: [id])
  timeline        LeadNote[]
  activities      ActivityLog[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([assignedToId])
}

// ---------------------------------------------------------------------
// LEAD NOTES — internal timeline of operator activity on a lead
// ---------------------------------------------------------------------
model LeadNote {
  id        String   @id @default(cuid())
  leadId    String
  authorId  String
  body      String
  kind      String   @default("note") // note | status_change | assignment | quote_sent
  createdAt DateTime @default(now())

  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id])

  @@index([leadId, createdAt])
}

// ---------------------------------------------------------------------
// FLEET — luxury vehicles available for hire
// ---------------------------------------------------------------------
model Fleet {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  category     String // sedan | suv | van | bus
  brand        String
  seats        Int
  luggage      Int
  description  String?
  imageUrl     String?
  features     String? // JSON-encoded array
  displayOrder Int      @default(0)
  isVisible    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([category, isVisible])
  @@index([displayOrder])
}

// ---------------------------------------------------------------------
// REVIEWS — moderation-gated client testimonials
// ---------------------------------------------------------------------
model Review {
  id          String   @id @default(cuid())
  clientName  String
  clientTitle String?
  rating      Int // 1-5
  body        String
  source      String   @default("direct") // direct | google
  isApproved  Boolean  @default(false)
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isApproved, isFeatured])
}

// ---------------------------------------------------------------------
// USERS — admin staff with role-based access
// Roles: super_admin | manager | operator
// ---------------------------------------------------------------------
model User {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String
  role        String   @default("operator") // super_admin | manager | operator
  isActive    Boolean  @default(true)
  avatarUrl   String?

  assignedLeads Lead[] @relation("AssignedLeads")
  notes        LeadNote[]
  activities   ActivityLog[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ---------------------------------------------------------------------
// ACTIVITY LOG — audit trail of every meaningful admin action
// ---------------------------------------------------------------------
model ActivityLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String // lead.created | lead.status_changed | lead.assigned | fleet.created | ...
  entityType String // lead | fleet | review | user
  entityId   String
  metadata   String? // JSON string
  ipAddress  String?
  leadId     String?
  createdAt  DateTime @default(now())

  user       User?    @relation(fields: [userId], references: [id])
  lead       Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([userId])
  @@index([leadId])
}
