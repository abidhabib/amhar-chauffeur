s-5 form-control input\" placeholder=\"Select Date\" required=\"\" tabindex=\"0\" type=\"text\" readonly=\"readonly\">\n                        </div>\n\n                        <!-- Time -->\n                        <div class=\"col-md-6 position-relative\">\n                            <i class=\"fa-solid fa-clock input-icon\"></i>\n                            <input type=\"text\" class=\"form-control ps-5 ui-timepicker-input\" id=\"time\" name=\"time\" placeholder=\"Select Time\" required=\"\" autocomplete=\"off\">\n                        </div>\n\n                        <!-- Name -->\n                        <div class=\"col-md-6 position-relative\">\n                            <i class=\"fa-solid fa-user input-icon\"></i>\n                            <input type=\"text\" class=\"form-control ps-5\" id=\"name\" name=\"name\" placeholder=\"Your Name\" required=\"\">\n                        </div>\n\n                        <!-- Contact -->\n                        <div class=\"col-md-6 position-relative\">\n                            <i class=\"fa-solid fa-phone input-icon\"></i>\n                            <input type=\"tel\" class=\"form-control ps-5\" id=\"contact\" name=\"contact\" placeholder=\"+966 5X XXX XXXX\" required=\"\" pattern=\"[0-9+]{8,15}\">\n                        </div>\n\n                        <!-- Email -->\n                        <div class=\"col-md-6 position-relative\">\n                            <i class=\"fa-solid fa-envelope input-icon\"></i>\n                            <input type=\"email\" class=\"form-control ps-5\" id=\"email\" name=\"email\" placeholder=\"you@example.com\" required=\"\">\n                        </div>\n\n                        <!-- Car Category Dropdown -->\n                        <div class=\"col-md-6 position-relative\">\n                            <i class=\"fa-solid fa-car input-icon\"></i>\n                            <select class=\"form-select ps-5\" id=\"car_category\" name=\"car_category\" required=\"\">\n                                <option value=\"\" disabled=\"\" selected=\"\">Select Car Category</option>\n                                <option value=\"Sedan\">Sedan</option>\n                                <option value=\"SUV\">SUV</option>\n                                <option value=\"VAN\">VAN</option>\n                                <option value=\"Other\">Other</option>\n                            </select>\n                        </div>\n\n                        <!-- Passengers with plus/minus -->\n\n                        <div class=\"col-md-6 position-relative quantity-wrapper extra-padding\">\n                            <i class=\"fa-solid fa-users input-icon2\"></i> <label for=\"passengers\" class=\"form-label\">\n                                Passengers</label>\n                            <div class=\"quantity-input\">\n                                <button type=\"button\" class=\"btn-qty minus\">−</button>\n                                <input type=\"number\" class=\"form-control qty-field\" id=\"passengers\" name=\"passengers\" value=\"1\" min=\"1\" step=\"1\" required=\"\">\n                                <button type=\"button\" class=\"btn-qty plus\">+</button>\n                            </div>\n                        </div>\n\n                        <!-- Luggage with plus/minus -->\n                        <div class=\"col-md-6 position-relative quantity-wrapper extra-padding\">\n                            <i class=\"fa-solid fa-suitcase-rolling input-icon2\"></i> <label for=\"passengers\" class=\"form-label\"> Luggage</label>\n                            <div class=\"quantity-input\">\n                                <button type=\"button\" class=\"btn-qty minus\">−</button>\n                                <input type=\"number\" class=\"form-control qty-field\" id=\"luggage\" name=\"luggage\" value=\"0\" min=\"0\" step=\"1\" required=\"\">\n                                <button type=\"button\" class=\"btn-qty plus\">+</button>\n                            </div>\n                        </div>\n\n                        <!-- reCAPTCHA -->\n                        <div class=\"col-12 text-center mb-2\">\n                            <div class=\"g-recaptcha\" data-sitekey=\"6Lf3qAwsAAAAAAtc40Gnp6G8SGq8N-mr79knVtXM\" data-callback=\"enableSubmit\" data-expired-callback=\"disableSubmit\"><div style=\"width: 304px; height: 78px;\"><div><iframe title=\"reCAPTCHA\" width=\"304\" height=\"78\" role=\"presentation\" name=\"a-t92tkq5fl0ew\" frameborder=\"0\" scrolling=\"no\" sandbox=\"allow-forms allow-popups allow-same-origin allow-scripts allow-top-navigation allow-modals allow-popups-to-escape-sandbox allow-storage-access-by-user-activation\" src=\"https://www.google.com/recaptcha/api2/anchor?ar=1&amp;k=6Lf3qAwsAAAAAAtc40Gnp6G8SGq8N-mr79knVtXM&amp;co=aHR0cHM6Ly9hbWhhcmtzYS5jb206NDQz&amp;hl=en&amp;v=MerVUtRoajKEbP7pLiGXkL28&amp;size=normal&amp;anchor-ms=20000&amp;execute-ms=30000&amp;cb=o12c3welcixl\"></iframe></div><textarea id=\"g-recaptcha-response\" name=\"g-recaptcha-response\" class=\"g-recaptcha-response\" style=\"width: 250px; height: 40px; border: 1px solid rgb(193, 193, 193); margin: 10px 25px; padding: 0px; resize: none; display: none;\"></textarea></div></div>\n                        </div>\n\n                        <!-- Submit -->\n                        <div class=\"col-12\">\n                            <button type=\"submit\" id=\"submit-btn\" class=\"btn btn-golden btn-md mt-1 w-100\" disabled=\"\">Book\n                                Now</button>\n                        </div>\n\n                    </div>\n                </form>\n\n            </div>\n        </div>\n    </div>\n</div>\n\n<!-- Flatpickr for Date -->\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css\">\n<script src=\"https://cdn.jsdelivr.net/npm/flatpickr\"></script>\n\n<!-- jQuery Timepicker -->\n<link rel=\"stylesheet\" href=\"https://