# PostgreSQL connection string — REQUIRED
# Get a free one at https://neon.tech (recommended, no install needed)
#
# Examples (see DEPLOY.md for full setup):
#   Neon:     postgresql://user:pass@ep-xxx.region.aws.neon.tech/amhar?sslmode=require
#   Supabase: postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres
#   Local:    postgresql://postgres:postgres@localhost:5432/amhar
#
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/amhar
