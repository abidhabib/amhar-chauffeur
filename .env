# Local development: PGlite (WASM Postgres) — no external DB needed
# The db.ts client uses PGlite directly via the Prisma driver adapter.
DATABASE_URL="postgresql://pglite:pglite@localhost:5432/amhar"

# Production: replace with your real Postgres connection string.
# Recommended providers (all have free tiers):
#   - Neon:        postgresql://user:pass@ep-xxx.region.aws.neon.tech/amhar?sslmode=require
#   - Vercel Postgres: postgresql://user:pass@xxx.db.vercel-storage.com/amhar
#   - Supabase:    postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres
#   - Railway:     postgresql://postgres:pass@xxx.railway.app:5432/railway
